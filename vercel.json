{
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    {
      "source": "/review-pakket",
      "destination": "/reviews",
      "permanent": true
    },
    {
      "source": "/website-laten-maken/barbershop",
      "destination": "/website-laten-maken/kapper",
      "permanent": true
    }
  ],
  "routes": [
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/404.html",
      "status": 404
    }
  ]
}